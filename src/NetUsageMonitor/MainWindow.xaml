<Window x:Class="NetUsageMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:NetUsageMonitor.Ui"
        Title="NetUsage Monitor" Height="680" Width="1080" MinHeight="480" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}"
        Icon="Assets/app.ico">

    <Window.Resources>
        <Style x:Key="NumCell" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="FontFamily" Value="Consolas" />
        </Style>
        <Style x:Key="RightHeader" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>
        <Style x:Key="StatLabel" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="Margin" Value="0,16,0,6" />
        </Style>
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ============ TOP BAR ============ -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo + title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="Assets/app.ico" Width="26" Height="26" Margin="0,0,8,0" />
                <TextBlock Text="NetUsage Monitor" FontSize="17" FontWeight="Bold" />
            </StackPanel>

            <!-- Search -->
            <Grid Grid.Column="1" Width="240" Margin="20,0,0,0">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Search apps…" Foreground="{StaticResource TextSecondary}"
                           Margin="10,0" IsHitTestVisible="False" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- View controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <Button Command="{Binding TogglePauseCommand}" Content="{Binding PauseButtonText}"
                        Style="{StaticResource ToolButton}" Margin="0,0,12,0"
                        ToolTip="Freeze the list so you can click a row (recording keeps running)" />
                <CheckBox Content="Auto-sort" IsChecked="{Binding AutoSort}" VerticalAlignment="Center"
                          ToolTip="Let rows reorder live by the sorted column (off = rows stay put)" />
            </StackPanel>

            <!-- Totals + actions -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="{StaticResource PanelBg}" CornerRadius="6" Padding="12,5" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↓" Foreground="{StaticResource AccentGreen}" FontWeight="Bold" />
                        <TextBlock Text="{Binding TotalDownText}" Margin="4,0,12,0" FontFamily="Consolas" />
                        <TextBlock Text="↑" Foreground="{StaticResource Accent}" FontWeight="Bold" />
                        <TextBlock Text="{Binding TotalUpText}" Margin="4,0,0,0" FontFamily="Consolas" />
                    </StackPanel>
                </Border>

                <Button Command="{Binding ToggleRecordingCommand}" Style="{StaticResource ToolButton}"
                        Margin="0,0,8,0" ToolTip="Pause or resume recording">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource AccentGreen}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="False">
                                            <Setter Property="Fill" Value="{StaticResource TextSecondary}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding RecordingText}" />
                    </StackPanel>
                </Button>

                <Button Content="Export" Command="{Binding ExportCsvCommand}"
                        Style="{StaticResource ToolButton}" Margin="0,0,8,0" ToolTip="Export the current list to CSV" />
                <Button Content="⚙ Settings" Click="OnSettingsClick" Style="{StaticResource ToolButton}" />
            </StackPanel>
        </Grid>

        <!-- ============ MAIN CONTENT ============ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="480" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="340" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <!-- Apps grid -->
            <Border Grid.Column="0" Background="{StaticResource PanelBg2}" CornerRadius="8" Padding="2">
                <DataGrid x:Name="AppsGrid"
                          ItemsSource="{Binding RowsView}"
                          SelectedItem="{Binding SelectedRow}"
                          CanUserSortColumns="True"
                          CanUserResizeRows="False">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Keep records indefinitely" IsCheckable="True"
                                                  IsChecked="{Binding PlacementTarget.DataContext.IsKept, RelativeSource={RelativeSource AncestorType=ContextMenu}, Mode=OneWay}"
                                                  Command="{Binding PlacementTarget.Tag.ToggleKeepCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Ignore this app (stop recording)" IsCheckable="True"
                                                  IsChecked="{Binding PlacementTarget.DataContext.IsIgnored, RelativeSource={RelativeSource AncestorType=ContextMenu}, Mode=OneWay}"
                                                  Command="{Binding PlacementTarget.Tag.ToggleIgnoreCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Separator />
                                        <MenuItem Header="Kill process"
                                                  Command="{Binding PlacementTarget.Tag.KillProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Separator />
                                        <MenuItem Header="Only track this app"
                                                  Command="{Binding PlacementTarget.Tag.OnlyTrackThisCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Track all apps"
                                                  Command="{Binding PlacementTarget.Tag.TrackAllCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Separator />
                                        <MenuItem Header="Delete this app's records"
                                                  Command="{Binding PlacementTarget.Tag.DeleteAppRecordsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Open file location"
                                                  Command="{Binding PlacementTarget.Tag.OpenFileLocationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Copy name"
                                                  Command="{Binding PlacementTarget.Tag.CopyNameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsIgnored}" Value="True">
                                    <Setter Property="Opacity" Value="0.45" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Application" Width="*" SortMemberPath="DisplayName">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" ToolTip="{Binding ExePath}">
                                        <Image Source="{Binding Icon}" Width="18" Height="18" Margin="0,0,8,0"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="↓ Rate" Binding="{Binding DownRate, Converter={StaticResource Rate}}"
                                            SortMemberPath="DownRate" Width="100"
                                            ElementStyle="{StaticResource NumCell}" HeaderStyle="{StaticResource RightHeader}" />
                        <DataGridTextColumn Header="↑ Rate" Binding="{Binding UpRate, Converter={StaticResource Rate}}"
                                            SortMemberPath="UpRate" Width="100"
                                            ElementStyle="{StaticResource NumCell}" HeaderStyle="{StaticResource RightHeader}" />
                        <DataGridTextColumn Header="↓ Hour" Binding="{Binding DownHour, Converter={StaticResource Bytes}}"
                                            SortMemberPath="DownHour" Width="95"
                                            ElementStyle="{StaticResource NumCell}" HeaderStyle="{StaticResource RightHeader}" />
                        <DataGridTextColumn Header="↑ Hour" Binding="{Binding UpHour, Converter={StaticResource Bytes}}"
                                            SortMemberPath="UpHour" Width="95"
                                            ElementStyle="{StaticResource NumCell}" HeaderStyle="{StaticResource RightHeader}" />
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalHour, Converter={StaticResource Bytes}}"
                                            SortMemberPath="TotalHour" Width="95"
                                            ElementStyle="{StaticResource NumCell}" HeaderStyle="{StaticResource RightHeader}" />

                        <DataGridTemplateColumn Header="Status" Width="120" SortMemberPath="StatusText">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                                 Fill="{Binding StatusText, Converter={StaticResource StatusBrush}}" />
                                        <TextBlock Text="{Binding StatusText}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" />

            <!-- Detail panel -->
            <Border Grid.Column="2" Background="{StaticResource PanelBg2}" CornerRadius="8" Padding="0">
                <Grid>
                    <!-- Empty state -->
                    <TextBlock Text="Select an app to see details, history, and controls."
                               Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="16"
                               VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"
                               Visibility="{Binding SelectedRow, Converter={StaticResource NullVis}, ConverterParameter=invert}" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16"
                                  Visibility="{Binding SelectedRow, Converter={StaticResource NullVis}}">
                        <StackPanel>
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Image Source="{Binding SelectedRow.Icon}" Width="28" Height="28" Margin="0,0,10,0" />
                                <TextBlock Text="{Binding SelectedRow.DisplayName}" FontSize="16" FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedRow.ExePath}" Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6" />

                            <!-- Status badges -->
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#EF4444" CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                                        Visibility="{Binding SelectedRow.IsBlocked, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="BLOCKED" FontSize="10" FontWeight="Bold" Foreground="White" />
                                </Border>
                                <Border Background="#F97316" CornerRadius="4" Padding="6,2"
                                        Visibility="{Binding SelectedRow.CapTripped, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="LIMIT REACHED" FontSize="10" FontWeight="Bold" Foreground="White" />
                                </Border>
                            </StackPanel>

                            <!-- Primary actions -->
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="{Binding SelectedRow.BlockText}" Command="{Binding BlockCommand}"
                                        CommandParameter="{Binding SelectedRow}" Style="{StaticResource SmallButton}" />
                                <Button Content="Kill process" Command="{Binding KillProcessCommand}"
                                        CommandParameter="{Binding SelectedRow}" Style="{StaticResource SmallButton}" />
                                <Button Content="Keep records" Command="{Binding ToggleKeepCommand}"
                                        CommandParameter="{Binding SelectedRow}" Style="{StaticResource SmallButton}" />
                                <Button Content="Ignore" Command="{Binding ToggleIgnoreCommand}"
                                        CommandParameter="{Binding SelectedRow}" Style="{StaticResource SmallButton}" />
                                <Button Content="Only track this" Command="{Binding OnlyTrackThisCommand}"
                                        CommandParameter="{Binding SelectedRow}" Style="{StaticResource SmallButton}" />
                            </WrapPanel>

                            <!-- Live + averages -->
                            <TextBlock Text="LIVE &amp; AVERAGES" Style="{StaticResource SectionHeader}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Live ↓" Style="{StaticResource StatLabel}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Live ↑" Style="{StaticResource StatLabel}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource StatValue}" Foreground="{StaticResource AccentGreen}"
                                           Text="{Binding SelectedRow.DownRate, Converter={StaticResource Rate}}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource StatValue}" Foreground="{StaticResource Accent}"
                                           Text="{Binding SelectedRow.UpRate, Converter={StaticResource Rate}}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Avg/min ↓ (last hr)" Style="{StaticResource StatLabel}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Avg/min ↑ (last hr)" Style="{StaticResource StatLabel}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource StatValue}" Text="{Binding SelectedRow.AvgPerMinDownText}" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource StatValue}" Text="{Binding SelectedRow.AvgPerMinUpText}" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="This session ↓" Style="{StaticResource StatLabel}" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="This session ↑" Style="{StaticResource StatLabel}" />
                                <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource StatValue}" Text="{Binding SelectedRow.SessionDown, Converter={StaticResource Bytes}}" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource StatValue}" Text="{Binding SelectedRow.SessionUp, Converter={StaticResource Bytes}}" />
                            </Grid>

                            <!-- History -->
                            <TextBlock Text="LAST HOUR" Style="{StaticResource SectionHeader}" />
                            <ui:UsageChart x:Name="Chart" Height="110" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreen}" Margin="0,0,5,0" />
                                <TextBlock Text="Download" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,14,0" />
                                <Ellipse Width="8" Height="8" Fill="{StaticResource Accent}" Margin="0,0,5,0" />
                                <TextBlock Text="Upload" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Last hour ↓" Style="{StaticResource StatLabel}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Last hour ↑" Style="{StaticResource StatLabel}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource StatValue}" Text="{Binding SelectedRow.DownHour, Converter={StaticResource Bytes}}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource StatValue}" Text="{Binding SelectedRow.UpHour, Converter={StaticResource Bytes}}" />
                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="Total recorded:" Style="{StaticResource StatLabel}" Margin="0,0,6,0" />
                                    <TextBlock x:Name="AllTimeText" Text="—" FontWeight="SemiBold" FontSize="12" />
                                </StackPanel>
                            </Grid>

                            <!-- Data limit -->
                            <TextBlock Text="DATA LIMIT (BLOCK WHEN REACHED)" Style="{StaticResource SectionHeader}" />
                            <TextBlock Text="{Binding SelectedRow.CapText}" FontSize="13" FontWeight="SemiBold" />
                            <ProgressBar Height="6" Minimum="0" Maximum="100" Value="{Binding SelectedRow.CapPercent}"
                                         Margin="0,5" Foreground="{StaticResource Accent}" Background="{StaticResource PanelBg}"
                                         BorderThickness="0"
                                         Visibility="{Binding SelectedRow.HasCap, Converter={StaticResource BoolVis}}" />
                            <WrapPanel>
                                <Button Content="Set / change limit" Click="OnSetCap" Style="{StaticResource SmallButton}" />
                                <Button Content="Reset counter" Command="{Binding ResetCapCommand}" CommandParameter="{Binding SelectedRow}"
                                        Style="{StaticResource SmallButton}" Visibility="{Binding SelectedRow.HasCap, Converter={StaticResource BoolVis}}" />
                                <Button Content="Remove limit" Command="{Binding ClearCapCommand}" CommandParameter="{Binding SelectedRow}"
                                        Style="{StaticResource SmallButton}" Visibility="{Binding SelectedRow.HasCap, Converter={StaticResource BoolVis}}" />
                            </WrapPanel>

                            <!-- Connections -->
                            <TextBlock Text="CONNECTIONS / DOMAINS" Style="{StaticResource SectionHeader}" />
                            <WrapPanel>
                                <Button Content="{Binding SelectedRow.RecordConnText}" Command="{Binding RecordConnectionsCommand}"
                                        CommandParameter="{Binding SelectedRow}" Style="{StaticResource SmallButton}" />
                                <Button Content="Clear" Command="{Binding ClearConnectionsCommand}" CommandParameter="{Binding SelectedRow}"
                                        Style="{StaticResource SmallButton}"
                                        Visibility="{Binding SelectedRow.IsRecordingConnections, Converter={StaticResource BoolVis}}" />
                            </WrapPanel>
                            <TextBlock Text="Turn on recording to capture the domains/IPs this app connects to. (Domains are best-effort; HTTPS URLs stay encrypted.)"
                                       FontSize="11" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6"
                                       Visibility="{Binding SelectedRow.IsRecordingConnections, Converter={StaticResource BoolVis}, ConverterParameter=invert}" />
                            <ItemsControl x:Name="ConnectionsList" MaxHeight="220"
                                          Visibility="{Binding SelectedRow.IsRecordingConnections, Converter={StaticResource BoolVis}}">
                                <ItemsControl.Template>
                                    <ControlTemplate TargetType="ItemsControl">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"><ItemsPresenter /></ScrollViewer>
                                    </ControlTemplate>
                                </ItemsControl.Template>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#15202E" CornerRadius="4" Padding="8,5" Margin="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Subtitle}" FontSize="10" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Records -->
                            <TextBlock Text="RECORDS" Style="{StaticResource SectionHeader}" />
                            <WrapPanel Margin="0,0,0,4">
                                <Button Content="Open file location" Command="{Binding OpenFileLocationCommand}"
                                        CommandParameter="{Binding SelectedRow}" Style="{StaticResource SmallButton}" />
                                <Button Content="Delete this app's records" Command="{Binding DeleteAppRecordsCommand}"
                                        CommandParameter="{Binding SelectedRow}" Style="{StaticResource SmallButton}" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ============ STATUS BAR ============ -->
        <Border Grid.Row="2" Background="{StaticResource PanelBg2}" CornerRadius="6" Padding="12,6" Margin="0,10,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding AppCountText}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding RetentionText}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding ModeText}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding DbSizeText}" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" Text="{Binding FolderText}" Foreground="{StaticResource TextSecondary}"
                           FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="420" ToolTip="{Binding FolderText}" />
            </Grid>
        </Border>
    </Grid>
</Window>
