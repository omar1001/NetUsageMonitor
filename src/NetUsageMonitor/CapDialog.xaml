<Window x:Class="NetUsageMonitor.CapDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set data limit" Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource WindowBg}" Icon="Assets/app.ico">
    <StackPanel Margin="18">
        <TextBlock x:Name="HeaderText" Text="Block this app when it uses more than:" TextWrapping="Wrap" FontSize="13" />
        <StackPanel Orientation="Horizontal" Margin="0,12">
            <TextBox x:Name="AmountBox" Width="90" Text="500" HorizontalContentAlignment="Center" />
            <ComboBox x:Name="UnitBox" Width="70" Margin="8,0" SelectedIndex="0">
                <ComboBoxItem>MB</ComboBoxItem>
                <ComboBoxItem>GB</ComboBoxItem>
            </ComboBox>
            <TextBlock Text="per" VerticalAlignment="Center" Margin="6,0" />
            <ComboBox x:Name="PeriodBox" Width="130" SelectedIndex="0">
                <ComboBoxItem>Total (until reset)</ComboBoxItem>
                <ComboBoxItem>Day</ComboBoxItem>
                <ComboBoxItem>Month</ComboBoxItem>
            </ComboBox>
        </StackPanel>
        <TextBlock Text="When the limit is reached, the app's internet is blocked and you get a notification. You can reset or remove the limit anytime."
                   Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Click="OnCancel" Style="{StaticResource ToolButton}" Width="90" Margin="0,0,8,0" />
            <Button Content="Set limit" Click="OnOk" Style="{StaticResource AccentButton}" Width="90" />
        </StackPanel>
    </StackPanel>
</Window>
